# pyenv
#   For a library or binary, you wish to ignore these files by default.
#   For a managed Python application, you may wish to check them in.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or even
#   fail to install them. In that case, the lock file should be added to .gitignore.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   poetry.lock
#   #   In some cases, you may want to ignore poetry.lock
#   #   poetry.lock

# pdm
#   Similar Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
#   pdm uses .pdm-python to remember which python interpreter to use,
#   so it should be ignored.
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/fannheyward/coc-pyright
__pypackages__/

